{
  "info": {
    "name": "HelpTata API",
    "description": "Colección completa de endpoints de HelpTata. Pasos: 1) Ejecuta 'Login' y copia el token. 2) Pégalo en la variable {{token}} del environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://helptata.cl", "type": "string" },
    { "key": "token",    "value": "",                    "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Autenticación",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); pm.test('Token guardado ✔', () => true); }"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"tu@correo.com\",\n  \"password\": \"tu_contraseña\"\n}" },
            "url": { "raw": "{{base_url}}/api/usuarios/login", "host": ["{{base_url}}"], "path": ["api","usuarios","login"] }
          }
        }
      ]
    },

    {
      "name": "👤 Usuarios",
      "item": [
        {
          "name": "GET todos los usuarios",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/usuarios", "host": ["{{base_url}}"], "path": ["api","usuarios"] } }
        },
        {
          "name": "GET usuario por ID",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/usuarios/1", "host": ["{{base_url}}"], "path": ["api","usuarios","1"] } }
        },
        {
          "name": "POST crear usuario",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"run_usuario\": \"12345678\",\n  \"dvrun_usuario\": \"9\",\n  \"pnombre_usuario\": \"Juan\",\n  \"snombre_usuario\": \"Carlos\",\n  \"papellido_usuario\": \"Pérez\",\n  \"sapellido_usuario\": \"González\",\n  \"fecha_nac_usuario\": \"1960-05-15\",\n  \"telefono_usuario\": \"+56912345678\",\n  \"password_usuario\": \"contraseña123\",\n  \"id_direccion\": null\n}" },
            "url": { "raw": "{{base_url}}/api/usuarios", "host": ["{{base_url}}"], "path": ["api","usuarios"] }
          }
        },
        {
          "name": "PUT actualizar usuario",
          "request": {
            "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"pnombre_usuario\": \"Juan\",\n  \"snombre_usuario\": \"Carlos\",\n  \"papellido_usuario\": \"Pérez\",\n  \"sapellido_usuario\": \"González\",\n  \"fecha_nac_usuario\": \"1960-05-15\",\n  \"telefono_usuario\": \"+56912345678\",\n  \"id_direccion\": null\n}" },
            "url": { "raw": "{{base_url}}/api/usuarios/1", "host": ["{{base_url}}"], "path": ["api","usuarios","1"] }
          }
        },
        {
          "name": "DELETE usuario",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/usuarios/1", "host": ["{{base_url}}"], "path": ["api","usuarios","1"] } }
        }
      ]
    },

